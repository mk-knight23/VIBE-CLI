{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "out",
    ".next"
  ],
  "references": [
    { "path": "./vibe-cli" },
    { "path": "./vibe-web" },
    { "path": "./vibe-code" }
  ]
}
