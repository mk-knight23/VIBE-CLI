{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  "files": [],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "out",
    ".next",
    "vibe-cli",
    "vibe-web",
    "vibe-code"
  ]
}
