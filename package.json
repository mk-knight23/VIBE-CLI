{
  "name": "vibe",
  "version": "2.0.0",
  "description": "Multi-Provider AI Development Platform - CLI, Web, and VS Code Extension",
  "private": true,
  "scripts": {
    "build": "npm run build:cli && npm run build:web && npm run build:code",
    "build:cli": "cd vibe-cli && npm run build",
    "build:web": "cd vibe-web && npm run build",
    "build:code": "cd vibe-code && npm run compile",
    "dev:web": "cd vibe-web && npm run dev",
    "test": "npm run test:cli && npm run test:web",
    "test:cli": "cd vibe-cli && npm test",
    "test:web": "cd vibe-web && npm test",
    "clean": "rm -rf vibe-cli/dist vibe-web/.next vibe-code/out",
    "install:all": "cd vibe-cli && npm install && cd ../vibe-web && npm install && cd ../vibe-code && npm install"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mk-knight23/vibe.git"
  },
  "keywords": [
    "ai",
    "cli",
    "vscode",
    "web",
    "openrouter",
    "megallm",
    "agentrouter",
    "routeway",
    "multi-provider",
    "code-generation",
    "assistant"
  ],
  "author": "VIBE Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mk-knight23/vibe/issues"
  },
  "homepage": "https://vibe-ai.vercel.app",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "vibe-ai-cli": "^4.0.0"
  }
}
